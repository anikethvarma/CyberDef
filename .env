# AegisNet Environment Configuration

# Application
APP_NAME=AegisNet
APP_VERSION=0.1.0
DEBUG=false

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
OLLAMA_TIMEOUT=600
OLLAMA_TEMPERATURE=0.1

# Database - SQLite (built-in)
DATABASE_URL=sqlite:///./data/aegisnet.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_ECHO=false

# Processing - Optimized for 45MB files
MAX_FILE_SIZE_MB=500
CHUNK_TIME_WINDOW_MINUTES=15
MAX_EVENTS_PER_BATCH=5000

# Agent Configuration
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=60
MIN_CONFIDENCE_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Authentication (multi-user SOC login)
# Username format: soc.<emp_id>
AUTH_USERNAME_PREFIX=soc.
AUTH_EMP_IDS=133745,2123486,2171569,473496,2858682,2832493,2795270
AUTH_EMP_NAME_MAP=133745:Shyam Kanan,2123486: ArunKumar Rajendran,2171569: Praveen,473496: Prasad N,2858682: Aman Panda,2832493: Aniketh,2795270: Anish Tejwani
AUTH_COMMON_PASSWORD=admin123
AUTH_SECRET_KEY=replace-this-secret-for-production
AUTH_TOKEN_TTL_MINUTES=480
